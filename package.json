{
  "name": "sip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SIP — Sistema de Implementação Prática (refactor Express + React). Mesmo banco Supabase; nova stack.",
  "main": "dist/server/index.js",
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "dev:server": "node --env-file=.env --watch --import tsx src/server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:server",
    "build:web": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p src/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
