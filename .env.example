# =============================================================================
# SIP — variáveis de ambiente do SERVER (Express). Copie para .env na raiz:
#   cp .env.example .env   (Windows: copy .env.example .env)
#
# NUNCA commite o .env real. Segredos reais ficam no painel da Hostinger (env do app Node).
# =============================================================================

# --- Obrigatório (boot-guard) -----------------------------------------------
# Mesma string usada hoje nas Edge Functions (mín. 32 chars). Reusar o MESMO
# secret de produção mantém os JWTs compatíveis entre a stack antiga e a nova.
SIP_JWT_SECRET=troque-por-um-segredo-de-no-minimo-32-caracteres

# --- Banco (mesmo projeto Supabase de produção: mbvybujpkwuorhtdzcde) --------
# Obrigatórias em produção. service_role BYPASSA RLS — só no servidor, nunca no front.
SUPABASE_URL=https://mbvybujpkwuorhtdzcde.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Porta (Passenger injeta automaticamente na Hostinger) ------------------
PORT=3000
NODE_ENV=development

# --- Integrações (necessárias só quando os respectivos serviços forem ligados) ---
RESEND_API_KEY=
CLICKUP_TOKEN=
CLICKUP_RETRY_SECRET=
IG_COLLECT_SECRET=
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
SIP_APP_URL=https://sip.grupoparticipa.app.br
